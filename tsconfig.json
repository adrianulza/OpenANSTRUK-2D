// VS Code shim — real config lives in config/tsconfig.json.
// This file exists only because VS Code's TS server requires tsconfig.json at the workspace root.
{
  "extends": "./config/tsconfig.json",
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "./src/**/*.ts",
    "./src/**/*.tsx",
    "./config/vite.config.ts",
    "./config/eslint.config.js"
  ],
  "exclude": ["./node_modules"]
}
